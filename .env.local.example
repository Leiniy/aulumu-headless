# Shopify Storefront API (公开，用于商品查询)
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=your-storefront-access-token

# Shopify Admin API (服务端专用，用于读取 metafields，不需要定义)
# 获取方式: Shopify后台 → Settings → Apps → Develop apps → 创建app → API credentials
SHOPIFY_ADMIN_ACCESS_TOKEN=your-admin-api-access-token

# Site URL (for Netlify)
NEXT_PUBLIC_SITE_URL=https://your-site.netlify.app


# ----------------------------------------------------
# Shopify Storefront API
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=your-storefront-access-token
SHOPIFY_ADMIN_ACCESS_TOKEN=your-admin-api-access-token